# Data443 LLM Gateway - Environment Variables

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO
UPSTREAM_TIMEOUT_SECONDS=60.0
TRUST_PROXY_HEADERS=false
STRICT_STARTUP_VALIDATION=false

# Proxy caller authentication (recommended on VPS)
PROXY_API_KEY_ENABLED=false
PROXY_API_KEY=

# Rate limiting (Optional)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_STORAGE=auto
RATE_LIMIT_REDIS_PREFIX=gw:ratelimit
RATE_LIMIT_PROXY_REQUESTS=120
RATE_LIMIT_ADMIN_REQUESTS=300
RATE_LIMIT_AUDIT_REQUESTS=120

# CORS (set explicit frontend origins in production)
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=false

# Cyren API Configuration
CYREN_IPREP_URL=https://try-now-ipreputation.data443.io/ctipd/iprep
CYREN_URLF_URL=https://try-now-urlcat.data443.io/ctwsd/websec
CYREN_API_KEY=
CYREN_TIMEOUT=5.0
CYREN_RETRY_ATTEMPTS=2
CTAS_URL=https://try-now-antispam.data443.io/ctasd/ClassifyMessage_Inline
CTAS_TIMEOUT=5.0

# Redis Configuration (L1/L2 Caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_L1_TTL=300
REDIS_L2_TTL=3600

# PostgreSQL Configuration (Audit Log)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=data443_audit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
AUDIT_RETENTION_DAYS=30
AUDIT_MASK_SENSITIVE_FIELDS=true
AUDIT_REDACT_MESSAGE_CONTENT=false
AUDIT_MAX_STRING_LENGTH=4000
AUDIT_PURGE_ENABLED=true
AUDIT_PURGE_INTERVAL_SECONDS=3600

# Target LLM Configuration (OpenAI)
LLM_PROVIDER=openai
LLM_ENDPOINT=https://api.openai.com
LLM_API_KEY=
OPENAI_ENDPOINT=https://api.openai.com
OPENAI_API_KEY=
ANTHROPIC_ENDPOINT=https://api.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_API_VERSION=2023-06-01
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com
GEMINI_API_KEY=
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Admin API Hardening
ADMIN_AUTH_ENABLED=true
ADMIN_AUTH_MODE=api_key
ADMIN_API_KEY=change_me_admin_key
ADMIN_ALLOWED_IPS=

# Agent Governance Hardening
AGENT_LINK_ENFORCEMENT_ENABLED=true
AGENT_INTERACTION_RETENTION_DAYS=30

# OpenTelemetry (Optional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=data443-llm-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_TIMEOUT_SECONDS=5.0

# DB migrations/bootstrap
DB_MIGRATIONS_ENABLED=true
DB_DDL_BOOTSTRAP_FALLBACK=false

# JWT Authentication (Optional)
JWT_ENABLED=false
JWT_SECRET=
JWT_ISSUER=data443-gateway
JWT_AUDIENCE=data443-gateway

# Policy Configuration
ALLOW_THRESHOLD=80
ALLOW_LOG_THRESHOLD=50
CONSTRAIN_THRESHOLD=20

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# Vaikora Control Plane (optional)
CONTROL_PLANE_ENABLED=false
CONTROL_PLANE_URL=
CONTROL_PLANE_API_KEY=
CONTROL_PLANE_POLICY_SYNC_INTERVAL=60
CONTROL_PLANE_AUDIT_PUSH_INTERVAL=30
CONTROL_PLANE_AUDIT_BATCH_SIZE=50
CONTROL_PLANE_HITL_POLL_INTERVAL=5
CONTROL_PLANE_HITL_TIMEOUT=300
CONTROL_PLANE_REQUEST_TIMEOUT=10.0
# Async HITL (202 + replay): HMAC secret for signed continuation tokens.
# - Required on the gateway whenever CONTROL_PLANE_ENABLED=true and you use require_approval policies.
# - Also required when STRICT_STARTUP_VALIDATION=true (fail-fast misconfig).
# Generate example: openssl rand -hex 32
CONTROL_PLANE_HITL_CONTINUATION_SECRET=
CONTROL_PLANE_HITL_CONTINUATION_TTL_SECONDS=3600