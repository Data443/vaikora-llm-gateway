# ============================================================
# Data443 LLM Gateway - Environment Configuration
# ============================================================
# On VPS: set real passwords for REDIS_PASSWORD, POSTGRES_PASSWORD,
#          ADMIN_API_KEY, and JWT_SECRET before starting.
# ============================================================

# ----- Server -----
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO
LOG_FORMAT=text
UPSTREAM_TIMEOUT_SECONDS=60.0
MAX_REQUEST_BODY_BYTES=10485760
TRUST_PROXY_HEADERS=false

# ----- Rate Limiting -----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_STORAGE=auto
RATE_LIMIT_REDIS_PREFIX=gw:ratelimit
RATE_LIMIT_PROXY_REQUESTS=120
RATE_LIMIT_ADMIN_REQUESTS=300
RATE_LIMIT_AUDIT_REQUESTS=120

# ----- CORS -----
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=false

# ----- Cyren Threat Intelligence -----
CYREN_IPREP_URL=https://try-now-ipreputation.data443.io/ctipd/iprep
CYREN_URLF_URL=https://try-now-urlcat.data443.io/ctwsd/websec
CYREN_API_KEY=
CYREN_TIMEOUT=5.0
CYREN_RETRY_ATTEMPTS=2
CYREN_FAIL_CLOSED=true
CTAS_URL=https://try-now-antispam.data443.io/ctasd/ClassifyMessage_Inline
CTAS_TIMEOUT=5.0

# ----- Redis (L1/L2 Caching) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=changeme_redis
REDIS_L1_TTL=300
REDIS_L2_TTL=3600

# ----- PostgreSQL (Audit Log) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=data443_audit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ----- Audit / Retention -----
AUDIT_RETENTION_DAYS=30
AUDIT_MASK_SENSITIVE_FIELDS=true
AUDIT_REDACT_MESSAGE_CONTENT=false
AUDIT_MAX_STRING_LENGTH=4000
AUDIT_PURGE_ENABLED=true
AUDIT_PURGE_INTERVAL_SECONDS=3600

# ----- Database Migrations -----
DB_MIGRATIONS_ENABLED=true
DB_DDL_BOOTSTRAP_FALLBACK=false

# ----- Target LLM Providers -----
LLM_PROVIDER=openai
LLM_ENDPOINT=https://api.openai.com
LLM_API_KEY=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
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ----- Policy Thresholds -----
ALLOW_THRESHOLD=80
ALLOW_LOG_THRESHOLD=50
CONSTRAIN_THRESHOLD=20

# ----- Circuit Breaker -----
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# ----- JWT Authentication -----
JWT_ENABLED=false
JWT_SECRET=
JWT_ISSUER=data443-gateway
JWT_AUDIENCE=data443-gateway

# ----- Admin API Hardening -----
ADMIN_AUTH_ENABLED=false
ADMIN_AUTH_MODE=api_key
ADMIN_API_KEY=change_me_admin_key
ADMIN_ALLOWED_IPS=

# ----- Proxy API Key Authentication -----
PROXY_API_KEY_ENABLED=true
PROXY_API_KEY=2d129d342c71cba3a47b2474eb0205e97d93e7de314ed3c741cf40a989fb5f94

# ----- Agent Governance -----
AGENT_LINK_ENFORCEMENT_ENABLED=true
A2A_INTERACTION_ENFORCEMENT_ENABLED=true
AGENT_INTERACTION_RETENTION_DAYS=30

# ----- OpenTelemetry (Optional) -----
OTEL_ENABLED=false
OTEL_SERVICE_NAME=data443-llm-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_TIMEOUT_SECONDS=5.0
